{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(astro:*)",
      "Bash(node:*)",
      "Bash(prettier:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(pwd)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(which:*)",
      "Bash(tsc:*)",

      "PowerShell(npm:*)",
      "PowerShell(npx:*)",
      "PowerShell(astro:*)",
      "PowerShell(node:*)",
      "PowerShell(prettier:*)",
      "PowerShell(git:*)",
      "PowerShell(gh:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Get-Content:*)",
      "PowerShell(Set-Location:*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(New-Item:*)",
      "PowerShell(Copy-Item:*)",
      "PowerShell(Move-Item:*)",
      "PowerShell(Select-String:*)",
      "PowerShell(Measure-Object:*)",
      "PowerShell(Write-Output:*)",
      "PowerShell(tsc:*)",

      "Read",
      "Edit(src/**)",
      "Edit(public/**)",
      "Edit(*.md)",
      "Edit(*.json)",
      "Edit(*.mjs)",
      "Edit(*.ts)",
      "Edit(.github/**)",

      "WebFetch(domain:docs.astro.build)",
      "WebFetch(domain:mcp.docs.astro.build)",
      "mcp__astro-docs__search_astro_docs"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Edit(dist/**)",
      "Edit(package-lock.json)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
