---
import { Image } from "astro:assets";
import StatusBadge from "./StatusBadge.astro";
import type { Project } from "../lib/projects";

interface Props {
  project: Project;
  hidden?: boolean;
}

const { project, hidden = false } = Astro.props;
const { data, id } = project;
const heroImage = data.poster ?? data.thumb; // poster preferred; falls back to thumb
const teaser = data.summary ?? data.blurb;
const tags = data.tags.slice(0, 6);
---

<article
  class="hero"
  data-project-hero
  data-project-id={id}
  data-category={data.category}
  hidden={hidden}
>
  <div class="hero__media">
    <Image
      class="hero__img"
      src={heroImage}
      alt={`${data.title} key art`}
      widths={[640, 960, 1280]}
      sizes="(max-width: 1120px) 100vw, 1080px"
      loading="lazy"
    />
    <div class="hero__scrim"></div>
  </div>

  <div class="hero__content">
    <span class="hero__label">Featured</span>
    <div class="hero__heading">
      <h2 class="hero__title">{data.title}</h2>
      <StatusBadge status={data.status} tone={data.statusTone} />
    </div>
    <p class="hero__teaser">{teaser}</p>
    {
      tags.length > 0 && (
        <ul class="hero__tags">
          {tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
    {/* Wired to open the modal in step 7; a static affordance for now. */}
    <span class="hero__action">View project</span>
  </div>
</article>

<style>
  .hero {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-strong);
    isolation: isolate;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background: var(--scrim);
  }

  .hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: flex-start;
    justify-content: flex-end;
    min-height: clamp(280px, 42vw, 420px);
    padding: clamp(1rem, 3vw, 2rem);
  }

  .hero__label {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .hero__heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .hero__title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: var(--text-primary);
  }
  .hero__teaser {
    max-width: 60ch;
    color: var(--text-secondary);
  }
  .hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
  }

  .hero__action {
    margin-top: 0.4rem;
    padding: 0.5rem 1.1rem;
    font-weight: 600;
    border-radius: var(--radius);
    background: var(--action-bg);
    color: var(--action-text);
  }
</style>
