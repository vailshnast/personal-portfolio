---
import { Image } from "astro:assets";
import StatusBadge from "./StatusBadge.astro";
import type { Project } from "../lib/projects";

interface Props {
  project: Project;
  hidden?: boolean;
}

const { project, hidden = false } = Astro.props;
const { data, id } = project;
const heroImage = data.poster ?? data.thumb; // poster preferred; falls back to thumb
const teaser = data.summary ?? data.blurb;
const tags = data.tags.slice(0, 6);
const hasPreview = Boolean(data.previewMp4 || data.previewWebm);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (p: string) => (p.startsWith("/") ? `${base}${p}` : p);
---

<article
  class="hero"
  data-project-hero
  data-project-id={id}
  data-category={data.category}
  hidden={hidden}
>
  <div class="hero__media">
    <Image
      class="hero__img"
      src={heroImage}
      alt={`${data.title} key art`}
      widths={[640, 960, 1280]}
      sizes="(max-width: 1120px) 100vw, 1080px"
      loading="lazy"
    />
    {
      hasPreview && (
        <video
          class="hero__video"
          data-preview
          muted
          loop
          playsinline
          preload="none"
          poster={heroImage.src}
        >
          {data.previewMp4 && (
            <source src={withBase(data.previewMp4)} type="video/mp4" />
          )}
          {data.previewWebm && (
            <source src={withBase(data.previewWebm)} type="video/webm" />
          )}
        </video>
      )
    }
    <span class="hero__label">Featured</span>
    <div class="hero__cue" aria-hidden="true"><span>View project →</span></div>
  </div>

  <div class="hero__body">
    <div class="hero__heading">
      <h2 class="hero__title">{data.title}</h2>
      <StatusBadge status={data.status} tone={data.statusTone} />
    </div>
    <p class="hero__teaser">{teaser}</p>
    {
      tags.length > 0 && (
        <ul class="hero__tags">
          {tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
  </div>

  {
    /* Transparent overlay: the accessible click/tap target that opens the modal. */
  }
  <button
    class="hero__open"
    type="button"
    data-open-modal
    data-project-id={id}
    aria-label={`Open ${data.title} details`}></button>
</article>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .hero__media {
    position: relative;
    height: clamp(150px, 24vw, 280px);
    background: var(--bg-surface-2);
  }
  .hero__img,
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__video {
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .hero.is-previewing .hero__video {
    opacity: 1;
  }
  .hero__label {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1;
    padding: 0.2rem 0.55rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-contrast);
    background: var(--accent);
    border-radius: var(--radius);
  }

  .hero__body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.45rem;
    padding: clamp(0.65rem, 1.8vw, 1rem);
  }
  .hero__heading {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .hero__title {
    font-size: clamp(1.2rem, 2.4vw, 1.55rem);
    font-weight: 700;
    color: var(--text-primary);
  }
  .hero__teaser {
    max-width: 70ch;
    font-size: 0.92rem;
    color: var(--text-secondary);
  }
  .hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Hover cue: a clear "click to open" affordance over the media. */
  .hero__cue {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    display: flex;
    justify-content: flex-end;
    padding: 0.7rem 0.75rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.55));
    opacity: 0;
    transition: opacity 0.15s ease;
    pointer-events: none;
  }
  .hero__cue span {
    padding: 0.35rem 0.85rem;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: var(--radius);
    background: var(--action-bg);
    color: var(--action-text);
  }

  .hero__open {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .hero__open:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  /* Highlight on hover (and keyboard focus), mirroring the grid cards. */
  @media (hover: hover) {
    .hero:hover .hero__cue {
      opacity: 1;
    }
  }
  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .hero {
      transition:
        transform 0.15s ease,
        box-shadow 0.15s ease;
    }
    .hero:hover {
      transform: translateY(-2px);
      box-shadow:
        0 0 0 1px var(--hover-ring),
        var(--ring-glow) var(--hover-ring);
    }
  }
  .hero:focus-within {
    box-shadow:
      0 0 0 1px var(--hover-ring),
      var(--ring-glow) var(--hover-ring);
  }
</style>
