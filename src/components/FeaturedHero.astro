---
import { Image } from "astro:assets";
import StatusBadge from "./StatusBadge.astro";
import type { Project } from "../lib/projects";

interface Props {
  project: Project;
  hidden?: boolean;
}

const { project, hidden = false } = Astro.props;
const { data, id } = project;
const heroImage = data.poster ?? data.thumb; // poster preferred; falls back to thumb
const teaser = data.summary ?? data.blurb;
const tags = data.tags.slice(0, 6);
const hasPreview = Boolean(data.previewMp4 || data.previewWebm);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (p: string) => (p.startsWith("/") ? `${base}${p}` : p);
---

<article
  class="hero"
  data-project-hero
  data-project-id={id}
  data-category={data.category}
  hidden={hidden}
>
  <div class="hero__media">
    <Image
      class="hero__img"
      src={heroImage}
      alt={`${data.title} key art`}
      widths={[640, 960, 1280]}
      sizes="(max-width: 1120px) 100vw, 1080px"
      loading="lazy"
    />
    {
      hasPreview && (
        <video
          class="hero__video"
          data-preview
          muted
          loop
          playsinline
          preload="none"
          poster={heroImage.src}
        >
          {data.previewMp4 && (
            <source src={withBase(data.previewMp4)} type="video/mp4" />
          )}
          {data.previewWebm && (
            <source src={withBase(data.previewWebm)} type="video/webm" />
          )}
        </video>
      )
    }
    <span class="hero__label">Featured</span>
  </div>

  <div class="hero__body">
    <div class="hero__heading">
      <h2 class="hero__title">{data.title}</h2>
      <StatusBadge status={data.status} tone={data.statusTone} />
    </div>
    <p class="hero__teaser">{teaser}</p>
    {
      tags.length > 0 && (
        <ul class="hero__tags">
          {tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
    <button
      class="hero__action"
      type="button"
      data-open-modal
      data-project-id={id}
    >
      View project
    </button>
  </div>
</article>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .hero__media {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--bg-surface-2);
  }
  .hero__img,
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__video {
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .hero.is-previewing .hero__video {
    opacity: 1;
  }
  .hero__label {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1;
    padding: 0.2rem 0.55rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-contrast);
    background: var(--accent);
    border-radius: var(--radius);
  }

  .hero__body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.7rem;
    padding: clamp(1rem, 2.5vw, 1.5rem);
  }
  .hero__heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .hero__title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--text-primary);
  }
  .hero__teaser {
    max-width: 70ch;
    color: var(--text-secondary);
  }
  .hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
  }
  .hero__action {
    margin-top: 0.2rem;
    padding: 0.55rem 1.2rem;
    font-weight: 600;
    border: 0;
    border-radius: var(--radius);
    background: var(--action-bg);
    color: var(--action-text);
    cursor: pointer;
  }
</style>
