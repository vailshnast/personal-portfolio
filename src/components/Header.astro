---
import { site } from "../config/site";
import ThemeToggle from "./ThemeToggle.astro";

// Minimal inline icons (currentColor). github is filled; the rest are stroked.
const icons: Record<string, string> = {
  github:
    '<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>',
  gitlab:
    '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M8 14 2 8.5l1-4 2 4h6l2-4 1 4L8 14Z"/></svg>',
  linkedin:
    '<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M3.4 1.6a1.4 1.4 0 1 0 0 2.8 1.4 1.4 0 0 0 0-2.8ZM2.2 5.5h2.4V14H2.2zM6.4 5.5h2.3v1.16h.03c.32-.6 1.1-1.23 2.27-1.23 2.43 0 2.88 1.6 2.88 3.68V14h-2.4V9.57c0-1.06-.02-2.42-1.48-2.42-1.48 0-1.7 1.16-1.7 2.35V14H6.4z"/></svg>',
  cv: '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M4 1.5h5l3 3v10H4z"/><path d="M9 1.5v3h3"/><path d="M6 8h4M6 11h4"/></svg>',
  mail: '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><rect x="1.5" y="3.5" width="13" height="9" rx="1"/><path d="M2 4.5 8 9l6-4.5"/></svg>',
  external:
    '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M6 3H3v10h10v-3"/><path d="M9.5 2.5H13.5v4"/><path d="M13 3 7.5 8.5"/></svg>',
};

// Resolve owner-relative links (e.g. "/cv.pdf") against the configured base so
// they keep working when deployed under a GitHub Pages subpath.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const resolve = (href: string) =>
  href.startsWith("/") ? `${base}${href}` : href;
const isExternal = (href: string) => href.startsWith("http");
---

<header class="site-header">
  <div class="identity">
    <span class="identity__name">{site.name}</span>
    <span class="identity__role">{site.role}</span>
  </div>

  <nav class="actions" aria-label="Profile links">
    {
      site.links.map((link) => (
        <a
          class="action-link"
          href={resolve(link.href)}
          target={isExternal(link.href) ? "_blank" : undefined}
          rel={isExternal(link.href) ? "noopener noreferrer" : undefined}
        >
          <span
            class="action-link__icon"
            aria-hidden="true"
            set:html={icons[link.icon] ?? icons.external}
          />
          <span>{link.label}</span>
        </a>
      ))
    }
    <ThemeToggle />
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    padding: 0.85rem clamp(1rem, 4vw, 2rem);
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border);
  }

  .identity {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .identity__name {
    font-weight: 700;
    color: var(--text-primary);
  }
  .identity__role {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .action-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.7rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--text-secondary);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    background: var(--bg-surface-2);
  }
  .action-link:hover {
    color: var(--text-primary);
    border-color: var(--accent);
  }
  .action-link__icon {
    display: inline-flex;
  }
</style>
