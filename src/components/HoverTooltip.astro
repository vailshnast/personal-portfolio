---
// Single reusable Steam-style teaser. Populated and positioned client-side from
// the hovered card's data-* attributes. Desktop/pointer only — never on touch.
---

<div class="tooltip" data-tooltip role="tooltip" aria-hidden="true">
  <div class="tooltip__head">
    <span class="tooltip__title" data-tt-title></span>
    <span class="badge" data-tt-badge hidden></span>
  </div>
  <p class="tooltip__summary" data-tt-summary></p>
  <ul class="tooltip__tags" data-tt-tags></ul>
  <span class="tooltip__cta">View project →</span>
</div>

<script>
  const tip = document.querySelector<HTMLElement>("[data-tooltip]");
  const canHover = window.matchMedia(
    "(hover: hover) and (pointer: fine)",
  ).matches;

  if (tip && canHover) {
    const titleEl = tip.querySelector<HTMLElement>("[data-tt-title]")!;
    const badgeEl = tip.querySelector<HTMLElement>("[data-tt-badge]")!;
    const summaryEl = tip.querySelector<HTMLElement>("[data-tt-summary]")!;
    const tagsEl = tip.querySelector<HTMLElement>("[data-tt-tags]")!;
    const parent = tip.parentElement!; // a positioned container (.page)

    let showTimer: number | undefined;
    let hideTimer: number | undefined;

    function fill(card: HTMLElement) {
      titleEl.textContent = card.dataset.title ?? "";
      const status = card.dataset.status;
      if (status) {
        badgeEl.textContent = status;
        badgeEl.className = `badge badge--${card.dataset.tone ?? "neutral"}`;
        badgeEl.hidden = false;
      } else {
        badgeEl.hidden = true;
      }
      summaryEl.textContent = card.dataset.summary ?? "";
      tagsEl.replaceChildren();
      (card.dataset.tags ?? "")
        .split("|")
        .filter(Boolean)
        .forEach((tag) => {
          const li = document.createElement("li");
          li.className = "tag";
          li.textContent = tag;
          tagsEl.appendChild(li);
        });
    }

    function position(card: HTMLElement) {
      const pRect = parent.getBoundingClientRect();
      const cRect = card.getBoundingClientRect();
      const tRect = tip!.getBoundingClientRect();
      const gap = 10;

      // Prefer the card's right side; flip left if it would overflow the viewport.
      let left = cRect.right + gap;
      if (left + tRect.width > window.innerWidth - 4) {
        left = cRect.left - gap - tRect.width;
      }
      if (left < 4)
        left = Math.min(cRect.left, window.innerWidth - tRect.width - 4);

      // Prefer aligning tops; anchor upward if it would overflow the bottom.
      let top = cRect.top;
      if (top + tRect.height > window.innerHeight - 4) {
        top = window.innerHeight - tRect.height - 4;
      }
      if (top < 4) top = 4;

      // Convert viewport coords to coords within the positioned parent.
      tip!.style.left = `${left - pRect.left}px`;
      tip!.style.top = `${top - pRect.top}px`;
    }

    function show(card: HTMLElement) {
      fill(card);
      tip!.classList.add("is-visible");
      position(card); // measure after it has layout
    }

    function hide() {
      tip!.classList.remove("is-visible");
    }

    document
      .querySelectorAll<HTMLElement>("[data-project-card]")
      .forEach((card) => {
        card.addEventListener("mouseenter", () => {
          window.clearTimeout(hideTimer);
          showTimer = window.setTimeout(() => show(card), 180);
        });
        card.addEventListener("mouseleave", () => {
          window.clearTimeout(showTimer);
          hideTimer = window.setTimeout(hide, 120);
        });
      });
  }
</script>

<style>
  .tooltip {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 50;
    width: 260px;
    max-width: 80vw;
    padding: 0.75rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.35),
      0 0 0 1px var(--hover-ring);
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition:
      opacity 0.12s ease,
      transform 0.12s ease;
    pointer-events: none;
  }
  .tooltip.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .tooltip__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .tooltip__title {
    font-weight: 700;
    color: var(--text-primary);
  }
  .tooltip__summary {
    font-size: 0.84rem;
    color: var(--text-secondary);
  }
  .tooltip__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tooltip__cta {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
  }
</style>
