---
// Compact icon-only platform badge (PC / Mobile / VR). Square and uniform; the
// platform name is exposed to assistive tech via aria-label / title.
interface Props {
  platform?: "PC" | "Mobile" | "VR";
}

const { platform } = Astro.props;

// Inline icons (currentColor), 16px, stroked to match the header icon style.
const icons: Record<string, string> = {
  PC: '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><rect x="1.5" y="2.5" width="13" height="8" rx="1"/><path d="M5.5 13.5h5M8 10.5v3"/></svg>',
  Mobile:
    '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><rect x="4.5" y="1.5" width="7" height="13" rx="1.5"/><path d="M7 12.5h2"/></svg>',
  VR: '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M2.5 5h11a1 1 0 0 1 1 1v3.2a1 1 0 0 1-1 1h-2.6l-1.4-1.6h-2L7.1 10.2H4.5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z"/></svg>',
};
---

{
  platform && (
    <span
      class={`platform platform--${platform.toLowerCase()}`}
      role="img"
      aria-label={`Platform: ${platform}`}
      title={platform}
      set:html={icons[platform]}
    />
  )
}

<style>
  .platform {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* Square and uniform across PC / Mobile / VR. `flex: none` stops it being
       squished in flex rows (e.g. the modal head next to the title). */
    flex: none;
    width: 32px;
    height: 32px;
    aspect-ratio: 1 / 1;
    color: var(--accent-contrast);
    background: var(--accent);
    border-radius: var(--radius);
  }
</style>
