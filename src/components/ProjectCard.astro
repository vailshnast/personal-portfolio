---
import { Image } from "astro:assets";
import StatusBadge from "./StatusBadge.astro";
import PlatformBadge from "./PlatformBadge.astro";
import { youtubeId, type Project } from "../lib/projects";

interface Props {
  project: Project;
  hidden?: boolean;
}

const { project, hidden = false } = Astro.props;
const { data, id } = project;
const tags = data.tags.slice(0, 4); // cap on the card; the modal shows them all
// When set, the hover preview is a YouTube embed; otherwise the card is static.
const ytId = youtubeId(data.youtube);

// Portrait media is letterboxed (object-fit: contain) over a blurred backdrop
// built from the thumbnail, instead of being cropped to the 16:9 frame.
const isPortrait = data.orientation === "portrait";
const mediaBg = isPortrait ? `--media-bg: url(${data.thumb.src})` : undefined;
---

<article
  class="card"
  data-project-card
  data-project-id={id}
  data-category={data.category}
  hidden={hidden}
>
  <div
    class:list={["card__media", { "card__media--portrait": isPortrait }]}
    style={mediaBg}
  >
    <Image
      class="card__img"
      src={data.thumb}
      alt={`${data.title} cover art`}
      widths={[520, 760, 1040, 1280]}
      sizes="(max-width: 600px) 92vw, (max-width: 1180px) 46vw, 520px"
      loading="lazy"
    />
    {
      ytId && (
        /* Facade: the iframe is injected on hover (see script) so the page
           never loads a YouTube player until the visitor actually hovers. */
        <div
          class="card__yt"
          data-yt-preview
          data-yt-id={ytId}
          aria-hidden="true"
        />
      )
    }
    {
      data.platform && (
        <div class="card__platform">
          <PlatformBadge platform={data.platform} />
        </div>
      )
    }
    {
      data.status && (
        <div class="card__badge">
          <StatusBadge status={data.status} tone={data.statusTone} />
        </div>
      )
    }
  </div>

  <div class="card__body">
    <h3 class="card__title">{data.title}</h3>
    <p class="card__blurb">{data.blurb}</p>
    {
      tags.length > 0 && (
        <ul class="card__tags">
          {tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
  </div>

  {
    /* Transparent overlay button: the accessible click/tap target that opens the modal. */
  }
  <button
    class="card__open"
    type="button"
    data-open-modal
    data-project-id={id}
    aria-label={`Open ${data.title} details`}></button>
</article>

<script>
  // Hover-only in-card YouTube preview. Gated behind a real pointer and motion
  // preference. The iframe is injected on enter and removed on leave, so the page
  // never loads a player up front and only the hovered card ever plays.
  const canHover = window.matchMedia(
    "(hover: hover) and (pointer: fine)",
  ).matches;
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (canHover && !reduce) {
    const hosts = document.querySelectorAll<HTMLElement>("[data-project-card]");
    hosts.forEach((host) => {
      const yt = host.querySelector<HTMLElement>("[data-yt-preview]");
      if (!yt) return;

      host.addEventListener("mouseenter", () => {
        host.classList.add("is-previewing");
        if (!yt.firstElementChild) {
          const id = yt.dataset.ytId!;
          const frame = document.createElement("iframe");
          // Muted, controls-free, looping autoplay = the silent hover loop.
          frame.src =
            `https://www.youtube-nocookie.com/embed/${id}` +
            `?autoplay=1&mute=1&loop=1&playlist=${id}` +
            `&controls=0&modestbranding=1&playsinline=1&rel=0&disablekb=1`;
          frame.allow = "autoplay; encrypted-media";
          frame.setAttribute("tabindex", "-1");
          frame.setAttribute("aria-hidden", "true");
          yt.appendChild(frame);
        }
      });

      host.addEventListener("mouseleave", () => {
        host.classList.remove("is-previewing");
        // Removing the iframe stops playback and frees the network/CPU.
        yt.replaceChildren();
      });
    });
  }
</script>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .card__media {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--bg-surface-2);
  }
  .card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* YouTube facade fills the frame; clicks fall through to the open button. */
  .card__yt {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .card__yt :global(iframe) {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  /* Portrait: show the whole frame (contain) over a blurred backdrop of itself. */
  .card__media--portrait::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--media-bg) center / cover no-repeat;
    filter: blur(22px) brightness(0.55);
    transform: scale(1.25);
  }
  .card__media--portrait .card__img {
    object-fit: contain;
    z-index: 1;
  }
  .card__yt {
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .card.is-previewing .card__yt {
    opacity: 1;
  }
  .card__badge {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 1;
  }
  .card__platform {
    position: absolute;
    top: 8px;
    left: 8px;
    z-index: 1;
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.6rem 0.7rem 0.75rem;
  }
  .card__title {
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .card__blurb {
    font-size: 0.82rem;
    color: var(--text-secondary);
  }
  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.1rem;
    list-style: none;
    padding: 0;
  }

  .card__open {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .card__open:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .card {
      transition:
        transform 0.15s ease,
        box-shadow 0.15s ease;
    }
    .card:hover {
      transform: scale(1.04);
      box-shadow:
        0 0 0 1px var(--hover-ring),
        var(--ring-glow) var(--hover-ring);
      z-index: 2;
    }
  }
</style>
