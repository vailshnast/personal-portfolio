---
import { Image } from "astro:assets";
import StatusBadge from "./StatusBadge.astro";
import type { Project } from "../lib/projects";

interface Props {
  project: Project;
  hidden?: boolean;
}

const { project, hidden = false } = Astro.props;
const { data, id } = project;
const tags = data.tags.slice(0, 4); // cap on the card; the modal shows them all
const hasPreview = Boolean(data.previewMp4 || data.previewWebm);

// Resolve public/ video paths against the deploy base.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (p: string) => (p.startsWith("/") ? `${base}${p}` : p);
---

<article
  class="card"
  data-project-card
  data-project-id={id}
  data-category={data.category}
  data-title={data.title}
  data-status={data.status ?? ""}
  data-tone={data.statusTone}
  data-summary={data.summary ?? data.blurb}
  data-tags={data.tags.join("|")}
  hidden={hidden}
>
  <div class="card__media">
    <Image
      class="card__img"
      src={data.thumb}
      alt={`${data.title} cover art`}
      widths={[178, 356, 534]}
      sizes="(max-width: 600px) 45vw, 220px"
      loading="lazy"
    />
    {
      hasPreview && (
        <video
          class="card__video"
          data-preview
          muted
          loop
          playsinline
          preload="none"
          poster={data.thumb.src}
        >
          {data.previewMp4 && (
            <source src={withBase(data.previewMp4)} type="video/mp4" />
          )}
          {data.previewWebm && (
            <source src={withBase(data.previewWebm)} type="video/webm" />
          )}
        </video>
      )
    }
    {
      data.status && (
        <div class="card__badge">
          <StatusBadge status={data.status} tone={data.statusTone} />
        </div>
      )
    }
  </div>

  <div class="card__body">
    <h3 class="card__title">{data.title}</h3>
    <p class="card__blurb">{data.blurb}</p>
    {
      tags.length > 0 && (
        <ul class="card__tags">
          {tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
  </div>

  {
    /* Transparent overlay button: the accessible click/tap target that opens the modal. */
  }
  <button
    class="card__open"
    type="button"
    data-open-modal
    data-project-id={id}
    aria-label={`Open ${data.title} details`}></button>
</article>

<script>
  // Hover-only in-card video preview. Gated behind a real pointer and motion
  // preference. Each element plays its own video on enter, pauses+resets on leave,
  // so only the hovered one ever plays.
  const canHover = window.matchMedia(
    "(hover: hover) and (pointer: fine)",
  ).matches;
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (canHover && !reduce) {
    const hosts = document.querySelectorAll<HTMLElement>(
      "[data-project-card], [data-project-hero]",
    );
    hosts.forEach((host) => {
      const video = host.querySelector<HTMLVideoElement>("video[data-preview]");
      if (!video) return;
      host.addEventListener("mouseenter", () => {
        host.classList.add("is-previewing");
        void video.play().catch(() => {});
      });
      host.addEventListener("mouseleave", () => {
        host.classList.remove("is-previewing");
        video.pause();
        video.currentTime = 0;
      });
    });
  }
</script>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .card__media {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--bg-surface-2);
  }
  .card__img,
  .card__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card__video {
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .card.is-previewing .card__video {
    opacity: 1;
  }
  .card__badge {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 1;
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.6rem 0.7rem 0.75rem;
  }
  .card__title {
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .card__blurb {
    font-size: 0.82rem;
    color: var(--text-secondary);
  }
  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.1rem;
    list-style: none;
    padding: 0;
  }

  .card__open {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .card__open:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .card {
      transition:
        transform 0.15s ease,
        box-shadow 0.15s ease;
    }
    .card:hover {
      transform: scale(1.04);
      box-shadow:
        0 0 0 1px var(--hover-ring),
        var(--ring-glow) var(--hover-ring);
      z-index: 2;
    }
  }
</style>
