---
import ProjectCard from "./ProjectCard.astro";
import type { Project } from "../lib/projects";

interface Props {
  projects: Project[];
  // The currently-featured project; its card is hidden so it isn't duplicated
  // (it appears in the hero instead). Filtering reassigns this client-side.
  featuredId: string;
}

const { projects, featuredId } = Astro.props;
---

<div class="grid">
  {
    projects.map((project) => (
      <ProjectCard project={project} hidden={project.id === featuredId} />
    ))
  }
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(178px, 1fr));
    gap: 14px;
  }
</style>
