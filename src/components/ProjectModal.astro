---
import { render } from "astro:content";
import StatusBadge from "./StatusBadge.astro";
import PlatformBadge from "./PlatformBadge.astro";
import BlockPuzzleBanner from "./banners/BlockPuzzleBanner.astro";
import FinanceTrackerBanner from "./banners/FinanceTrackerBanner.astro";
import { youtubeId, type Project } from "../lib/projects";

interface Props {
  projects: Project[];
}

// Same live-banner registry as ProjectCard: a project's `banner` frontmatter key
// selects a CSS banner to fill the modal media frame in place of the `thumb`
// poster. Kept in lockstep with the Zod enum (unknown key → build error).
const BANNERS = {
  "block-puzzle": BlockPuzzleBanner,
  "finance-tracker": FinanceTrackerBanner,
} as const;

const { projects } = Astro.props;

// Pre-render each project's Markdown body once; one hidden panel per project is
// reused as the modal content (spec-sanctioned "per-project hidden templates").
const panels = await Promise.all(
  projects.map(async (project) => ({
    project,
    Content: (await render(project)).Content,
  })),
);
---

<div class="modal" data-modal hidden>
  <div class="modal__backdrop" data-modal-close></div>
  <div class="modal__dialog" role="dialog" aria-modal="true">
    <button
      class="modal__close"
      type="button"
      data-modal-close
      aria-label="Close dialog"
    >
      <span aria-hidden="true">✕</span>
    </button>
    <div class="modal__scroll">
      {
        panels.map(({ project, Content }) => {
          const d = project.data;
          const ytId = youtubeId(d.youtube);
          const posterSrc = d.thumb.src;
          // A component banner fills the 16:9 frame itself (its own backdrop +
          // layout), bypassing the poster image and portrait letterbox below.
          const Banner = d.banner ? BANNERS[d.banner] : undefined;
          const isPortrait = !Banner && d.orientation === "portrait";
          const mediaBg = isPortrait
            ? `--media-bg: url(${posterSrc})`
            : undefined;
          // Component-banner projects (e.g. FinanceTracker) lead the modal with
          // their own content (a demo clip up top) instead of a hero media frame;
          // the banner still appears on the grid card. Everything else shows its
          // video/poster here.
          const showMedia = !Banner;
          return (
            <section
              class="panel"
              data-modal-panel
              data-project-id={project.id}
              hidden
            >
              {showMedia && (
                <div
                  class:list={[
                    "panel__media",
                    { "panel__media--portrait": isPortrait },
                  ]}
                  style={mediaBg}
                >
                  {ytId ? (
                    /* Iframe injected on open (see script) so a closed modal
                       never loads a YouTube player. */
                    <div
                      class="panel__yt"
                      data-modal-yt
                      data-yt-id={ytId}
                      data-yt-title={d.title}
                    />
                  ) : (
                    <img
                      class="panel__poster"
                      src={posterSrc}
                      alt={`${d.title} poster`}
                    />
                  )}
                </div>
              )}

              <div class="panel__head">
                <h2 class="panel__title" id={`modal-title-${project.id}`}>
                  {d.title}
                </h2>
                <PlatformBadge platform={d.platform} />
                <StatusBadge status={d.status} tone={d.statusTone} />
                {d.links.length > 0 && (
                  <div class="panel__head-actions">
                    {d.links.map((link) => (
                      <a
                        class="panel__link panel__head-cta"
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-link-type={link.type}
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
              <p class="panel__meta">{d.category}</p>
              {d.summary && <p class="panel__lead">{d.summary}</p>}

              <div class="prose">
                <Content />
              </div>

              <ul class="panel__tags">
                {d.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            </section>
          );
        })
      }
    </div>
  </div>
</div>

<script>
  const modal = document.querySelector<HTMLElement>("[data-modal]");

  if (modal) {
    const dialog = modal.querySelector<HTMLElement>(".modal__dialog")!;
    const closeBtn = modal.querySelector<HTMLElement>(".modal__close")!;
    const panels = Array.from(
      modal.querySelectorAll<HTMLElement>("[data-modal-panel]"),
    );
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    let lastTrigger: HTMLElement | null = null;

    const activePanel = () => panels.find((p) => !p.hidden) ?? null;

    function focusable(): HTMLElement[] {
      return Array.from(
        dialog.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), video[controls], iframe, [tabindex]:not([tabindex="-1"])',
        ),
      ).filter((el) => el.offsetParent !== null);
    }

    function open(id: string, trigger: HTMLElement) {
      const panel = panels.find((p) => p.dataset.projectId === id);
      if (!panel) return;
      lastTrigger = trigger;
      panels.forEach((p) => {
        p.hidden = p !== panel;
      });
      dialog.setAttribute("aria-labelledby", `modal-title-${id}`);
      modal!.hidden = false;
      document.documentElement.style.overflow = "hidden";

      const yt = panel.querySelector<HTMLElement>("[data-modal-yt]");
      if (yt) {
        const id = yt.dataset.ytId!;
        // Muted autoplay (so it starts despite browser policy); controls let
        // the visitor unmute/seek/fullscreen. Reduced motion → no autoplay.
        const frame = document.createElement("iframe");
        frame.src =
          `https://www.youtube-nocookie.com/embed/${id}` +
          `?autoplay=${reduce ? 0 : 1}&mute=1&controls=1` +
          `&modestbranding=1&playsinline=1&rel=0`;
        frame.allow =
          "autoplay; encrypted-media; picture-in-picture; fullscreen";
        frame.allowFullscreen = true;
        frame.title = `${yt.dataset.ytTitle ?? "Project"} video`;
        yt.replaceChildren(frame);
      }

      // Inline "About" clips: lightweight looping <video> injected into their
      // placeholders (a static poster image only, under reduced motion). Paths
      // go through BASE_URL so they resolve under the GitHub Pages subpath.
      const base = import.meta.env.BASE_URL.replace(/\/$/, "");
      panel
        .querySelectorAll<HTMLElement>("[data-about-clip]")
        .forEach((slot) => {
          if (slot.firstElementChild) return;
          const path = `${base}/${slot.dataset.aboutClip}`;
          if (reduce) {
            const img = document.createElement("img");
            img.src = `${path}.poster.avif`;
            img.alt = "";
            img.addEventListener("load", () => {
              if (img.naturalWidth)
                slot.style.setProperty(
                  "--clip-ar",
                  `${img.naturalWidth} / ${img.naturalHeight}`,
                );
            });
            slot.appendChild(img);
            return;
          }
          const v = document.createElement("video");
          v.muted = true;
          v.loop = true;
          v.autoplay = true;
          v.playsInline = true;
          v.preload = "none";
          v.poster = `${path}.poster.avif`;
          v.addEventListener("loadedmetadata", () => {
            if (v.videoWidth)
              slot.style.setProperty(
                "--clip-ar",
                `${v.videoWidth} / ${v.videoHeight}`,
              );
          });
          for (const [ext, type] of [
            ["webm", "video/webm"],
            ["mp4", "video/mp4"],
          ] as const) {
            const s = document.createElement("source");
            s.src = `${path}.${ext}`;
            s.type = type;
            v.appendChild(s);
          }
          slot.appendChild(v);
          void v.play().catch(() => {});
        });

      closeBtn.focus();
    }

    function close() {
      if (modal!.hidden) return;
      const panel = activePanel();
      // Removing the iframe stops playback (and any audio) immediately.
      panel?.querySelector<HTMLElement>("[data-modal-yt]")?.replaceChildren();
      // Tear down inline About clips so they stop looping once the modal closes.
      panel
        ?.querySelectorAll<HTMLElement>("[data-about-clip]")
        .forEach((slot) => slot.replaceChildren());
      modal!.hidden = true;
      document.documentElement.style.overflow = "";
      panels.forEach((p) => {
        p.hidden = true;
      });
      lastTrigger?.focus();
      lastTrigger = null;
    }

    document
      .querySelectorAll<HTMLElement>("[data-open-modal]")
      .forEach((trigger) => {
        trigger.addEventListener("click", () =>
          open(trigger.dataset.projectId ?? "", trigger),
        );
      });
    modal.querySelectorAll<HTMLElement>("[data-modal-close]").forEach((el) => {
      el.addEventListener("click", close);
    });

    modal.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        event.preventDefault();
        close();
        return;
      }
      if (event.key !== "Tab") return;
      const items = focusable();
      if (items.length === 0) return;
      const first = items[0];
      const last = items[items.length - 1];
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });
  }
</script>

<style>
  .modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(1rem, 5vh, 3rem) 1rem;
  }
  .modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
  }
  .modal__dialog {
    position: relative;
    width: min(900px, 100%);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .modal__scroll {
    overflow-y: auto;
    /* Reserve the scrollbar's space so it never overlaps the media/content. */
    scrollbar-gutter: stable;
    padding: clamp(1rem, 3vw, 1.75rem);
  }
  /* Floating close button: a solid circular control that sits clearly above the
     video and clear of the scrollbar gutter (right offset > the reserved gutter). */
  .modal__close {
    position: absolute;
    top: 0.75rem;
    right: 1rem;
    z-index: 5;
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-strong);
    border-radius: 50%;
    background: var(--bg-surface-2);
    color: var(--text-primary);
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }
  .modal__close:hover {
    border-color: var(--accent);
  }

  .panel__media {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-surface-2);
    margin-bottom: 1rem;
  }
  .panel__poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Inline "About" clips embedded in the rendered Markdown description.
     800×350 source; let it scale to the prose width without layout shift. */
  .prose :global(.about-clip) {
    margin: 1rem 0;
    /* Default reserves space; the script sets --clip-ar to the media's real
       ratio once it loads, so different clips never get cropped or distorted. */
    aspect-ratio: var(--clip-ar, 16 / 9);
    background: var(--bg-surface-2);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .prose :global(.about-clip > video),
  .prose :global(.about-clip > img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .panel__yt {
    position: absolute;
    inset: 0;
  }
  .panel__yt :global(iframe) {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  /* Portrait: contain over a blurred backdrop of the poster. */
  .panel__media--portrait::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--media-bg) center / cover no-repeat;
    filter: blur(28px) brightness(0.55);
    transform: scale(1.25);
  }
  .panel__media--portrait .panel__poster {
    position: relative;
    object-fit: contain;
    z-index: 1;
  }

  .panel__head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  /* Action links promoted into the head, grouped and pushed to the right after
     the badges so e.g. "View on GitHub" and "View Docs" sit side by side. */
  .panel__head-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-left: auto;
  }
  .panel__head-cta {
    flex: none;
    padding: 0.4rem 0.85rem;
    font-size: 0.82rem;
  }
  .panel__title {
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-weight: 700;
    color: var(--text-primary);
  }
  .panel__meta {
    margin: 0.2rem 0 0.75rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .panel__lead {
    margin: 0 0 1rem;
    font-size: 1.02rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .panel__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 1.1rem 0;
  }

  .panel__link {
    padding: 0.5rem 1rem;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius);
    background: var(--action-bg);
    color: var(--action-text);
  }
  .panel__link[data-link-type="external"],
  .panel__link[data-link-type="demo"] {
    background: var(--bg-surface-2);
    color: var(--text-primary);
    border: 1px solid var(--border-strong);
  }
</style>
