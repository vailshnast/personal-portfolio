---
// Badge classes are styled globally (src/styles/global.css) so the tooltip and
// modal can reuse them.
interface Props {
  status?: string;
  tone?: "green" | "blue" | "neutral";
}

const { status, tone = "neutral" } = Astro.props;
---

{status && <span class={`badge badge--${tone}`}>{status}</span>}
