---
// Accessible dark/light toggle. Logic lives in src/lib/theme.ts; the sun/moon
// glyph is swapped purely via CSS keyed off <html data-mode>.
---

<button
  type="button"
  class="theme-toggle"
  data-theme-toggle
  aria-pressed="false"
  aria-label="Switch color mode"
>
  <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true"
    >☀</span
  >
  <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true"
    >☾</span
  >
</button>

<script>
  import { initThemeToggle } from "../lib/theme.ts";
  initThemeToggle();
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    font-size: 1.1rem;
    line-height: 1;
    border-radius: var(--radius);
    border: 1px solid var(--border-strong);
    background: var(--bg-surface-2);
    color: var(--text-primary);
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease;
  }

  .theme-toggle:hover {
    border-color: var(--accent);
  }

  .theme-toggle__icon {
    display: none;
  }

  /* Dark mode → offer the sun (switch to light). Light mode → offer the moon. */
  :global(html[data-mode="dark"]) .theme-toggle__icon--sun {
    display: inline;
  }

  :global(html[data-mode="light"]) .theme-toggle__icon--moon {
    display: inline;
  }
</style>
