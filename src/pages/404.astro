---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import { site } from "../config/site";

// Home link resolves under the GitHub Pages subpath.
const home = import.meta.env.BASE_URL;
---

<BaseLayout title={`Page not found — ${site.name}`}>
  <Header />
  <main id="main" class="notfound" tabindex="-1">
    <p class="notfound__code">404</p>
    <h1 class="notfound__title">This page wandered off.</h1>
    <p class="notfound__text">
      The page you’re looking for doesn’t exist or has moved.
    </p>
    <a class="notfound__home" href={home}>← Back to projects</a>
  </main>
</BaseLayout>

<style>
  .notfound {
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(3rem, 12vw, 7rem) clamp(1rem, 4vw, 2rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
  }
  .notfound__code {
    font-size: clamp(3rem, 12vw, 6rem);
    font-weight: 800;
    line-height: 1;
    color: var(--accent);
  }
  .notfound__title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--text-primary);
  }
  .notfound__text {
    color: var(--text-secondary);
  }
  .notfound__home {
    margin-top: 0.8rem;
    padding: 0.5rem 1rem;
    font-weight: 600;
    border-radius: var(--radius);
    background: var(--action-bg);
    color: var(--action-text);
    text-decoration: none;
  }
  .notfound__home:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
