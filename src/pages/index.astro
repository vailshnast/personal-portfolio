---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import FilterTabs from "../components/FilterTabs.astro";
import FeaturedHero from "../components/FeaturedHero.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import HoverTooltip from "../components/HoverTooltip.astro";
import ProjectModal from "../components/ProjectModal.astro";
import { getProjects } from "../lib/projects";

const projects = await getProjects();
// Hero = first project overall for the default "All" view; filtering recomputes
// it client-side (see FilterTabs). Each project is pre-rendered as both a hero
// and a card so no JS is needed to see the catalog.
const featuredId = projects.length > 0 ? projects[0].id : "";
---

<BaseLayout>
  <Header />
  <main class="page">
    {
      projects.length === 0 ? (
        <p class="empty">No projects yet.</p>
      ) : (
        <>
          <FilterTabs />
          <section class="featured" aria-label="Featured project">
            {projects.map((project, i) => (
              <FeaturedHero project={project} hidden={i !== 0} />
            ))}
          </section>
          <section class="catalog" aria-label="All projects">
            <ProjectGrid projects={projects} featuredId={featuredId} />
            <p class="empty" data-projects-empty hidden>
              No projects in this category yet.
            </p>
          </section>
          <HoverTooltip />
        </>
      )
    }
  </main>
  {projects.length > 0 && <ProjectModal projects={projects} />}
</BaseLayout>

<style>
  .page {
    position: relative; /* positioning context for the absolutely-placed tooltip */
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(1rem, 4vw, 2rem) clamp(1rem, 4vw, 2rem) 4rem;
  }

  .featured {
    margin-bottom: 1.5rem;
  }

  .empty {
    padding: 2rem 0;
    color: var(--text-muted);
    text-align: center;
  }
</style>
